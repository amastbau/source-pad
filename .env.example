# === LLM Configuration ===

# Option A: Ollama on your PC (default)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# Option B: Phone LLM via hybrid-llm (uncomment these, keep OLLAMA_URL for embeddings)
# LLM_PROVIDER=local
# LOCAL_LLM_URL=http://localhost:8080
# LLM_MODEL=gemma-2-2b-it-q4_k_m.gguf

# === GitHub (for indexing repos) ===
# GITHUB_TOKEN=ghp_...

# === ChromaDB storage (defaults to ./data/chroma) ===
# CHROMA_PATH=./data/chroma
